# ===========================================
# SupportFlow AI - Configuração de Ambiente
# ===========================================
# No modo SaaS multi-cliente, as variáveis abaixo são GLOBAIS (do dono da
# plataforma). Cada cliente configura o PRÓPRIO e-mail/WhatsApp pela interface
# web, após o login — esses dados NÃO ficam aqui.

# --- Segurança (OBRIGATÓRIO em produção) ---
# Assina as sessões de login e criptografa os segredos dos clientes.
# Gere um valor forte e único (ex.: `openssl rand -hex 32`).
SECRET_KEY=troque-por-um-segredo-forte-e-unico

# --- Cérebro de IA — escolha do provedor (Gemini por padrão) ---
# LLM_PROVIDER: "gemini" (padrão) ou "claude" (Anthropic).
# >>> Para migrar para a Claude depois, basta 2 linhas:
#       LLM_PROVIDER=claude
#       ANTHROPIC_API_KEY=sua-chave-anthropic   (https://console.anthropic.com)
# Nada de código muda — todas as features de IA passam a usar a Claude.
LLM_PROVIDER=gemini

# Gemini (provedor padrão atual) — https://aistudio.google.com/
AI_API_KEY=sua-chave-api-gemini
GEMINI_MODEL=gemini-3.1-flash-lite

# Claude (Anthropic) — só usado quando LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Envio de e-mail (Resend — recomendado em produção) ---
# O Railway BLOQUEIA saída SMTP, então o envio de respostas usa a API HTTP do
# Resend (https://resend.com). UMA conta central serve todos os clientes; eles
# não precisam configurar nada. O remetente é o domínio verificado (RESEND_FROM)
# e o Reply-To é o e-mail do próprio cliente. Sem RESEND_API_KEY, cai no SMTP.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Suporte Floatech <atendimento@floatech.app>

# --- Automação ---
# Intervalo de sincronização do scheduler (vale para todos os clientes).
SYNC_INTERVAL_MINUTES=2

# --- Servidor web ---
# HOST=0.0.0.0      # padrão; no Railway a porta vem da variável PORT
# PORT=8000

# --- Banco de dados (opcional: MySQL/PostgreSQL) ---
# DATABASE_URL=sqlite:///./support_flow.db

# --- Marca ---
COMPANY_NAME=Floatech
