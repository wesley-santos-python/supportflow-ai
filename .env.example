# ===========================================
# SupportFlow AI - Configuração de Ambiente
# ===========================================
# Estas variáveis são opcionais: tudo também pode ser configurado pela
# tela de Configurações da interface web. As configurações salvas no banco
# têm prioridade sobre estas variáveis de ambiente.

# --- Credenciais de E-mail (Gmail/Outlook) ---
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app
EMAIL_PROVIDER=gmail
# IMAP_SERVER=imap.gmail.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# --- API Google Gemini ---
# Obtenha em: https://aistudio.google.com/
AI_API_KEY=sua-chave-api-gemini
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Automação ---
SYNC_INTERVAL_MINUTES=2
AUTO_DOWNLOAD_ATTACHMENTS=false

# --- Servidor web ---
HOST=127.0.0.1
PORT=8000

# --- Banco de dados (opcional: MySQL/PostgreSQL) ---
# DATABASE_URL=sqlite:///./support_flow.db

# --- WhatsApp (resumo de urgentes — futuro) ---
WHATSAPP_ENABLED=false
WHATSAPP_TO=
# WHATSAPP_TOKEN=

# --- Marca ---
COMPANY_NAME=Floatech
