# ===========================================
# SupportFlow AI - Configuração de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com seus valores.

# --- Banco de dados ---
# PostgreSQL (padrão). Troque a URL para usar SQLite/MySQL sem alterar código.
#   SQLite:  sqlite:///./support_flow.db
#   MySQL:   mysql+pymysql://user:pass@host:3306/dbname
DATABASE_URL=postgresql+psycopg://supportflow:supportflow@localhost:5432/supportflow

# --- Credenciais de E-mail (IMAP) ---
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app
IMAP_SERVER=imap.gmail.com
FETCH_LIMIT=10

# --- Google Gemini ---
# Obtenha em: https://aistudio.google.com/
AI_API_KEY=sua-chave-api-gemini
AI_MODEL=gemini-2.5-flash-lite

# --- Aplicação ---
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
