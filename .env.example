# ===========================================
# SupportFlow AI - Configuração de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com seus valores

# Credenciais de E-mail (Gmail)
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app

# API Google Gemini
# Obtenha em: https://aistudio.google.com/
AI_API_KEY=sua-chave-api-gemini

# Servidor IMAP (opcional, default: imap.gmail.com)
# IMAP_SERVER=imap.gmail.com
